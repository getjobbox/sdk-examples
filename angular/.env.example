# Copy to .env and fill in your key from JobBox Settings → Developer
JOBBOX_API_KEY=
JOBBOX_BASE_URL=https://api.getjobbox.com

# Angular UI (ng serve)
PORT=5178

# Node API proxy used by npm run dev (proxied from ng serve)
API_PORT=5179

# Python API proxy (npm run dev:python)
PYTHON_API_HOST=127.0.0.1
PYTHON_API_PORT=5179

# Public JobBox app origin used for “Apply on JobBox” (opens /j/:id)
# Injected at runtime via index if needed; format utils default to app.getjobbox.com
VITE_JOBBOX_APP_URL=https://app.getjobbox.com
