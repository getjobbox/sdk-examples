{
    "name": "jobbox/codeigniter-example",
    "description": "JobBox PHP SDK example - CodeIgniter 4 job board (mirrors the Vue demo)",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "getjobbox/sdk": "@dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php spark serve --port 8080"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../php",
            "options": {
                "symlink": true
            }
        }
    ]
}
