#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'

#--------------------------------------------------------------------
# JOBBOX SDK
# Copy JOBBOX_API_KEY and JOBBOX_BASE_URL from ../vue/.env
# Map VITE_JOBBOX_APP_URL → JOBBOX_APP_URL
# Create your key in JobBox → Settings → Developer. Never commit .env.
#--------------------------------------------------------------------
JOBBOX_API_KEY =
JOBBOX_BASE_URL = https://api.getjobbox.com
JOBBOX_APP_URL = https://app.getjobbox.com
