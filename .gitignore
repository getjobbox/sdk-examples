# Secrets - keep .env.example tracked
.env
.env.local
.env.*.local
!.env.example

# Dependencies
node_modules/
vendor/
.next/

# CodeIgniter writable runtime
**/writable/cache/*
!**/writable/cache/index.html
**/writable/logs/*
!**/writable/logs/index.html
**/writable/session/*
!**/writable/session/index.html
**/writable/debugbar/*
!**/writable/debugbar/index.html


# Build output
dist/
.angular/

# OS / editor
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
