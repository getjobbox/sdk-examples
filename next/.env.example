# Copy to .env.local and fill in your key from JobBox Settings → Developer
# (same values as ../vue/.env — map VITE_JOBBOX_APP_URL → NEXT_PUBLIC_JOBBOX_APP_URL)

JOBBOX_API_KEY=
JOBBOX_BASE_URL=https://api.getjobbox.com

# Public JobBox app origin used for "Apply on JobBox" (opens /j/:id)
NEXT_PUBLIC_JOBBOX_APP_URL=https://app.getjobbox.com
